rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ──────────────────────────────────────────────
    // Default: deny all reads and writes
    // ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ──────────────────────────────────────────────
    // Live Agent Metrics (read-only from client)
    // Writes are performed exclusively by the
    // simulation-worker via Firebase Admin SDK,
    // which bypasses these rules entirely.
    // ──────────────────────────────────────────────

    match /pulse_metrics/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /transit_schedules/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /access_logs/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /wayfinder_routes/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /polyglot_streams/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /verde_stats/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ──────────────────────────────────────────────
    // Venue metadata (read-only)
    // ──────────────────────────────────────────────
    match /venues/{venueId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
